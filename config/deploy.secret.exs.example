# Copy this file to config/deploy.secret.exs and fill in your values.
# This file is gitignored and will not be committed.
#
# Alternatively, set environment variables:
#   TOMATO_DEPLOY_HOST, TOMATO_DEPLOY_PORT, TOMATO_DEPLOY_USER,
#   TOMATO_DEPLOY_IDENTITY_FILE (recommended) or TOMATO_DEPLOY_PASSWORD (legacy).

import Config

config :tomato, Tomato.Deploy,
  host: "192.168.64.3",
  port: 22,
  user: "root",
  # Recommended: SSH public-key auth. Point at a private key whose directory
  # also contains the matching standard-named file (id_ed25519 or id_rsa).
  # The walker uses Erlang :ssh with `user_dir` set to Path.dirname(identity_file).
  identity_file: Path.expand("~/.ssh/id_ed25519"),
  # Legacy password auth — lab and trusted-network only. Remove once
  # identity_file is set and working.
  password: "tomato"
